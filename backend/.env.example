# KrishiMitra AI - Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/krishimitra

# JWT Secret
JWT_SECRET=krishimitra_secret_key_2024_change_this

# AI API Keys (add at least one)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Weather API (OpenWeatherMap)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Government Agmarket API (data.gov.in)
AGMARKET_API_KEY=your_agmarket_api_key_here
